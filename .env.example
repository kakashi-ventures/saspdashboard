# OpenAI — paraphrase + theme tagging via gpt-4o-mini.
# v0 uses OpenAI because the project key on Vercel is sk-proj-… (an OpenAI key).
# Methodology is LLM-vendor-agnostic; swap to Anthropic / others by editing
# api/_lib/paraphrase.ts. Set in Vercel project → Settings → Environment Variables.
OPENAI_API_KEY=sk-proj-...

# Validator login — single shared password for v0.
# Auth header: Basic base64("validator:$VALIDATOR_PASSWORD")
VALIDATOR_PASSWORD=change-me-before-deploy

# Vercel KV — injected automatically when you attach Upstash via Marketplace.
# Do not commit real values. Left here for documentation.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# Optional — bot identity sent to crawl targets. Identify honestly; do not spoof a browser.
INGEST_USER_AGENT=SASP-research/1.0 (+https://kakashi.ventures)
